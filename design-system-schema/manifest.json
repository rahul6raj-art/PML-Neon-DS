  "conventions": {
    "colorPrimitivePrefix": "--primitive-",
    "componentsUseSemanticColors": "Prefer tokens under tokens.colorSemanticForComponents; do not reference --primitive-* in UI components.",
    "cardStroke": "Default Card has no outer stroke unless design requires stroke prop.",
    "textfieldInCard": "Override fixed TextField width in screen CSS when inside Card (see pml-screen-patterns / LoginPage.css)."
  }
