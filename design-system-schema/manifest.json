{
  "$schema": "./manifest.schema.json",
  "schemaVersion": "1.0.0",
  "name": "PML Storybook / App design system",
  "dsSource": "PML-DS26-Tokens",
  "documentation": {
    "humanSpec": "DESIGN.md",
    "screenPatterns": ".cursor/rules/pml-screen-patterns.mdc",
    "components": "src/components/",
    "stories": "*.stories.tsx under src/"
  },
  "tokenSources": [
    { "path": "src/tokens/colors.css", "role": "color-primitives-and-semantics" },
    { "path": "src/tokens/numbers.css", "role": "spacing-radius-layout-primitives" },
    { "path": "src/tokens/typography.css", "role": "typography-tokens-and-utilities" }
  ],
  "themes": [
    {
      "id": "light",
      "description": "Default :root semantic colors in colors.css"
    },
    {
      "id": "dark",
      "selector": "[data-theme='dark']",
      "description": "Dark overrides for semantic color tokens"
    }
  ],
  "layoutContract": {
    "phoneColumnWidthVar": "--phone-column-width",
    "phoneColumnWidthPx": 376,
    "contentWellWidthVar": "--card-width",
    "contentWellWidthPx": 344,
    "horizontalGutterVar": "--spacing-16",
    "sectionGapVar": "--spacing-56",
    "defaultCardPaddingBlockVar": "--card-padding-block",
    "defaultCardPaddingInlineVar": "--card-padding-inline",
    "defaultCardRadiusVar": "--radius-24",
    "pageBackgroundSemantic": "--surface-level-4",
    "scrollRegionClassPattern": ".sh-content",
    "inrFormatting": "No space between ₹ and amount (e.g. ₹8,00,694)"
  },
  "tokens": {
    "unitPrimitives": [
      "--unit-1",
      "--unit-2",
      "--unit-3",
      "--unit-4",
      "--unit-6",
      "--unit-7",
      "--unit-9",
      "--unit-10",
      "--unit-11",
      "--unit-12",
      "--unit-13",
      "--unit-max"
    ],
    "spacingSemantic": [
