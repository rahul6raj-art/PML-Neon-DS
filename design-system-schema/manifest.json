    "heatmapLayout": [
      "--heatmap-sector-card-width",
      "--heatmap-mosaic-min-height",
      "--heatmap-cell-min-height",
      "--heatmap-cell-compact-min-height",
      "--heatmap-mosaic-min-height-tall",
