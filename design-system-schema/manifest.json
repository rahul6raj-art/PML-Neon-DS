      "--spacing-4",
      "--spacing-6",
      "--spacing-8",
      "--spacing-12",
      "--spacing-16",
      "--spacing-24",
      "--spacing-32",
      "--spacing-48",
      "--spacing-56",
      "--spacing-60"
    ],
    "layoutSemantic": [
      "--card-padding-block",
      "--card-padding-inline",
      "--phone-column-width",
      "--card-width",
      "--carousel-card-width",
      "--border-width-hairline",
      "--touch-target-standard"
